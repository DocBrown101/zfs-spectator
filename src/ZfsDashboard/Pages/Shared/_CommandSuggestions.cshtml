@model List<CommandSuggestion>
@if (Model.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body bg-surface">
            <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                <i class="bi bi-terminal text-info"></i>
                Mutation-Commands
            </h5>
            @foreach (var cmd in Model)
            {
                <div class="mb-3">
                    <div class="small text-body-secondary mb-1">@cmd.Description</div>
                    <div class="cmd-block">
                        <pre class="bg-dark text-light p-2 rounded"><code>@cmd.ZfsCommand</code></pre>
                        <button type="button" class="btn btn-sm btn-outline-secondary btn-copy" data-bs-toggle="tooltip" data-bs-title="Copy to clipboard">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                    @if (cmd.NixOsConfig is not null)
                    {
                        <details class="small mt-1">
                            <summary class="text-info">NixOS alternative</summary>
                            <div class="cmd-block mt-1">
                                <pre class="bg-dark text-light p-2 rounded"><code>@cmd.NixOsConfig</code></pre>
                                <button type="button" class="btn btn-sm btn-outline-secondary btn-copy" data-bs-toggle="tooltip" data-bs-title="Copy to clipboard">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                        </details>
                    }
                </div>
            }
        </div>
    </div>
}
