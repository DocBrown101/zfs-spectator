@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@functions {
    void Row(string label, object value, string? id = null, bool last = false)
    {
        var border = last ? "" : "border-bottom border-secondary";
        <div class="row py-2 @border small">
            <div class="col-5 text-body-secondary">@label</div>
            <div class="col-7" id="@id">@value</div>
        </div>
    }
}

<div class="d-flex justify-content-between align-items-center mb-1">
    <h3 class="fw-bold mb-0">
        <i class="bi bi-grid-1x2 me-2 text-info"></i>System Dashboard
    </h3>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-body-tertiary text-body-secondary border" id="sysUptimeBadge">
            <i class="bi bi-clock me-1"></i><span id="sysUptime">@Model.SystemInfo.Uptime</span>
        </span>
    </div>
</div>
<p class="text-body-secondary mb-4">Overview of system resources and ZFS pools</p>

<div class="row g-4">

    @* ── Left Column: System Info ────────────────────────────── *@
    <div class="col-lg-6">

        @* Network *@
        <div class="card mb-4">
            <div class="card-body bg-surface">
                <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-ethernet text-info"></i>
                    Network
                </h5>
                <canvas id="netCanvas"></canvas>
                <div id="netCharts"></div>
            </div>
        </div>

        @* CPU *@
        <div class="card mb-4">
            <div class="card-body bg-surface">
                <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-cpu text-info"></i>
                    CPU
                </h5>
                <div class="d-flex align-items-center gap-4">
                    <div class="position-relative flex-shrink-0" style="width:110px;height:110px">
                        <canvas id="cpuCanvas"></canvas>
                        <div class="position-absolute top-50 start-50 translate-middle text-center">
                            <span class="fw-bold fs-5" id="cpuPct">@Model.CpuUsagePercent.ToString("F1")%</span>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        @{ Row("Processor", Model.SystemInfo.Processor, "sysProcessor"); }
                        @{ Row("CPU Count", Model.SystemInfo.CpuCount.ToString(), "cpuCount", last: true); }
                    </div>
                </div>
            </div>
        </div>

        @* Memory *@
        <div class="card mb-4">
            <div class="card-body bg-surface">
                <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-memory text-info"></i>
                    Memory
                </h5>
                @{ Row("Total Memory", Model.Memory.Total.FormatBytes(), "memTotal"); }
                @{ Row("Available Memory", Model.Memory.Available.FormatBytes(), "memAvail"); }
                @{ Row("Used Memory", Model.Memory.Used.FormatBytes(), "memUsed"); }
                @{ Row("Percentage Used", $"{Model.Memory.UsagePercent:F1} %", "memPct"); }
                @{ Row("Buffers / Cached", $"{Model.Memory.Buffers.FormatBytes()} / {Model.Memory.Cached.FormatBytes()}", "memBuffersCached"); }
                @{ Row("Swap Used", $"{Model.Memory.SwapUsed.FormatBytes()} / {Model.Memory.SwapTotal.FormatBytes()}", "swapUsed"); }
                @{ Row("Swap Usage", $"{Model.Memory.SwapUsagePercent:F1} %", "swapPct", last: true); }
            </div>
        </div>

        @* ARC Statistics *@
        @if (Model.Arc.MaxSize > 0)
        {
            <div class="card mb-4">
                <div class="card-body bg-surface">
                    <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-speedometer2 text-info"></i>
                        ARC Cache
                    </h5>
                    @{ Row("ARC Size", $"{Model.Arc.Size.FormatBytes()} / {Model.Arc.MaxSize.FormatBytes()}", "arcSize"); }
                    @{
                        var hitClass = Model.Arc.HitRate >= 90 ? "text-success" : Model.Arc.HitRate >= 70 ? "text-warning" : "text-danger";
                        Row("L1 Hit Rate", Html.Raw($"<span class=\"{hitClass} fw-semibold\">{Model.Arc.HitRate:F1}%</span>"), "arcHitRate");
                    }
                    @if (Model.Arc.L2Size > 0)
                    {
                        var l2Class = Model.Arc.L2HitRate >= 70 ? "text-success" : "text-warning";
                        Row("L2ARC Hit Rate", Html.Raw($"<span class=\"{l2Class} fw-semibold\">{Model.Arc.L2HitRate:F1}% ({Model.Arc.L2Size.FormatBytes()})</span>"), "l2HitRate");
                    }
                    @if (Model.Arc.MetadataSize > 0)
                    {
                        Row("Metadata", Model.Arc.MetadataSize.FormatBytes(), "arcMeta");
                    }
                    @if (Model.Arc.DataSize > 0)
                    {
                        Row("Data", Model.Arc.DataSize.FormatBytes(), "arcData");
                    }
                    @if (Model.Arc.MruSize > 0 || Model.Arc.MfuSize > 0)
                    {
                        Row("MRU / MFU", $"{Model.Arc.MruSize.FormatBytes()} / {Model.Arc.MfuSize.FormatBytes()}", "arcMruMfu", last: true);
                    }
                </div>
            </div>
        }
    </div>

    @* ── Right Column: ZFS Pools ─────────────────────────────── *@
    <div class="col-lg-6">
        @* VDEV I/O *@
        <div class="card mb-4">
            <div class="card-body bg-surface">
                <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-hdd text-info"></i>
                    VDEV I/O
                </h5>
                <canvas id="diskCanvas"></canvas>
                <div class="table-responsive mt-2">
                    <table class="table table-borderless table-sm mb-0 small" style="table-layout:fixed">
                        <colgroup>
                            <col style="width:30%">
                            <col style="width:35%">
                            <col style="width:35%">
                        </colgroup>
                        <thead>
                            <tr class="border-bottom border-secondary">
                                <th class="text-body-secondary fw-normal">Device</th>
                                <th class="text-body-secondary fw-normal text-end">Read</th>
                                <th class="text-body-secondary fw-normal text-end">Write</th>
                            </tr>
                        </thead>
                        <tbody id="diskDetail">
                            <tr><td colspan="3" class="text-body-secondary">Loading&hellip;</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* ZFS Pools *@
        <div class="card mb-4">
            <div class="card-body bg-surface">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title d-flex align-items-center gap-2 mb-0">
                        <i class="bi bi-hdd-stack text-info"></i>
                        ZFS Pools
                    </h5>
                    <span class="badge bg-body-tertiary text-body-secondary border">@Model.Pools.Count pools</span>
                </div>

                @* Heatmap Legend *@
                <div class="d-flex flex-wrap gap-3 mb-3 small text-body-secondary">
                    <span><span class="heatmap-legend-swatch" style="background:#198754"></span> &lt;1 ms</span>
                    <span><span class="heatmap-legend-swatch" style="background:#20c997"></span> 1–5 ms</span>
                    <span><span class="heatmap-legend-swatch" style="background:#ffc107"></span> 5–10 ms</span>
                    <span><span class="heatmap-legend-swatch" style="background:#fd7e14"></span> 10–20 ms</span>
                    <span><span class="heatmap-legend-swatch" style="background:#dc3545"></span> 20–50 ms</span>
                    <span><span class="heatmap-legend-swatch" style="background:#b02a37"></span> &gt;50 ms</span>
                </div>

                @if (Model.Pools.Count == 0)
                {
                    <div class="alert alert-secondary mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        No ZFS pools found. Ensure ZFS is installed and pools are imported.
                    </div>
                }

                @foreach (var pool in Model.Pools)
                {
                    var pct = pool.UsagePercent;
                    var barCss = pct > 85 ? "bg-danger" : pct > 70 ? "bg-warning" : "bg-success";

                    <div class="card mb-3">
                        <div class="card-body py-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <a asp-page="/Pools/Details" asp-route-name="@pool.Name" class="fw-semibold text-info text-decoration-none">
                                        <i class="bi bi-hdd-stack me-1" style="font-size:.8rem"></i>@pool.Name
                                    </a>
                                    @if (pool.Encrypted)
                                    {
                                        <i class="bi bi-lock-fill text-warning ms-1" data-bs-toggle="tooltip" data-bs-title="Encrypted (@pool.EncryptionAlgorithm)"></i>
                                    }
                                    @if (pool.HasErrors)
                                    {
                                        <span class="badge bg-danger ms-1" data-bs-toggle="tooltip" data-bs-title="R:@pool.ErrorsRead W:@pool.ErrorsWrite C:@pool.ErrorsChecksum">
                                            <i class="bi bi-exclamation-triangle"></i>
                                        </span>
                                    }
                                </div>
                                <span class="badge @pool.Health.ToStatusBadgeCss()">@pool.Health</span>
                            </div>
                            <div class="row text-center small">
                                <div class="col">
                                    <div class="text-body-secondary text-uppercase" style="font-size:.7rem">Size</div>
                                    <div class="fw-semibold">@pool.UsableSize.FormatBytes()</div>
                                </div>
                                <div class="col">
                                    <div class="text-body-secondary text-uppercase" style="font-size:.7rem">Allocated</div>
                                    <div class="fw-semibold">@pool.UsableUsed.FormatBytes()</div>
                                </div>
                                <div class="col">
                                    <div class="text-body-secondary text-uppercase" style="font-size:.7rem">Free</div>
                                    <div class="fw-semibold">@pool.UsableAvail.FormatBytes()</div>
                                </div>
                                <div class="col">
                                    <div class="text-body-secondary text-uppercase" style="font-size:.7rem">Capacity</div>
                                    <div class="d-flex align-items-center justify-content-center gap-2">
                                        <span class="fw-semibold">@pct.ToString("F0")%</span>
                                        <div class="progress" style="width:60px;height:8px;">
                                            <div class="progress-bar @barCss" style="width:@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            @* VDEV Latency Heatmap for this pool *@
                            <div class="row g-2 mt-2" id="heatmap-@pool.Name"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        function fmtRate(v) {
            const u = ['B/s','KiB/s','MiB/s','GiB/s'];
            for (let i = 0; i < u.length; i++) { if (v < 1024 || i === u.length - 1) return v.toFixed(1) + ' ' + u[i]; v /= 1024; }
        }

        function rollingChart(canvasId, label0, color0, label1, color1) {
            const labels = [], d0 = [], d1 = [];
            const chart = new Chart(document.getElementById(canvasId), {
                type: 'line',
                data: { labels, datasets: [
                    { label: label0, data: d0, borderColor: color0, backgroundColor: color0 + '18', fill: true, tension: 0.3, pointRadius: 0, borderWidth: 1.5 },
                    { label: label1, data: d1, borderColor: color1, backgroundColor: color1 + '18', fill: true, tension: 0.3, pointRadius: 0, borderWidth: 1.5 },
                ]},
                options: {
                    animation: false, responsive: true, aspectRatio: 4,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { labels: { boxWidth: 10, color: '#adb5bd', font: { size: 11 } } },
                        tooltip: { callbacks: { label: c => c.dataset.label + ': ' + fmtRate(c.parsed.y) } },
                    },
                    scales: {
                        x: { ticks: { display: false }, grid: { color: 'rgba(255,255,255,0.05)' } },
                        y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#adb5bd', font: { size: 10 }, callback: fmtRate } },
                    },
                },
            });
            return function (v0, v1) {
                labels.push(''); d0.push(v0); d1.push(v1);
                if (labels.length > 60) { labels.shift(); d0.shift(); d1.shift(); }
                chart.update();
            };
        }

        const pushNet  = rollingChart('netCanvas',  'Download', '#0dcaf0', 'Upload', '#ffc107');
        const pushDisk = rollingChart('diskCanvas', 'Read',     '#0dcaf0', 'Write',  '#ffc107');

        function cpuColor(p) { return p > 85 ? '#dc3545' : p > 70 ? '#ffc107' : '#0dcaf0'; }
        const initCpu = @(Model.CpuUsagePercent.ToString("F1", System.Globalization.CultureInfo.InvariantCulture));
        const cpuChart = new Chart(document.getElementById('cpuCanvas'), {
            type: 'doughnut',
            data: { datasets: [{ data: [initCpu, 100 - initCpu], backgroundColor: [cpuColor(initCpu), 'rgba(255,255,255,0.08)'], borderWidth: 0 }] },
            options: { cutout: '75%', responsive: true, plugins: { legend: { display: false }, tooltip: { enabled: false } }, animation: { duration: 300 } },
        });

        // ── Heatmap helpers ─────────────────────────────────────
        const hColors = [[0,'#6c757d','rgba(108,117,125,0.12)'],[1,'#198754','rgba(25,135,84,0.20)'],
            [5,'#20c997','rgba(32,201,151,0.20)'],[10,'#ffc107','rgba(255,193,7,0.20)'],
            [20,'#fd7e14','rgba(253,126,20,0.22)'],[50,'#dc3545','rgba(220,53,69,0.25)'],
            [Infinity,'#b02a37','rgba(176,42,55,0.30)']];
        function pick(ms, i) { for (const [t,fg,bg] of hColors) if (ms < t) return i ? bg : fg; return hColors[0][i?2:1]; }
        function fmtMs(ms) { return ms <= 0 ? 'idle' : ms < 10 ? ms.toFixed(2) : ms.toFixed(1); }
        function fmtOps(o) { return o >= 1000 ? (o/1000).toFixed(1)+'K' : o < 10 ? o.toFixed(1) : Math.round(o)+''; }
        const esc = s => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };

        function heatCell(d) {
            const c = pick(Math.max(d.readLatencyMs, d.writeLatencyMs), 0);
            const hot = d.utilizationPct > 80 ? ' heatmap-hot' : '';
            const ub = d.utilizationPct > 80 ? 'bg-danger' : d.utilizationPct > 50 ? 'bg-warning' : 'bg-info';
            return `<div class="col-6 col-xl-4"><div class="card heatmap-cell${hot}" style="border-left:4px solid ${c}">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="font-monospace small fw-semibold text-truncate me-2" title="${esc(d.devicePath)}">${esc(d.deviceName)}</span>
                        <span class="badge bg-secondary flex-shrink-0">${esc(d.role)}</span>
                    </div>
                    <div class="row g-1 text-center mb-2">
                        <div class="col-6"><div class="heatmap-value rounded" style="background:${pick(d.readLatencyMs,1)}">
                            <div class="text-uppercase text-body-secondary" style="font-size:.6rem">Read</div>
                            <div class="fw-semibold" style="color:${pick(d.readLatencyMs,0)}">${fmtMs(d.readLatencyMs)} ms</div>
                        </div></div>
                        <div class="col-6"><div class="heatmap-value rounded" style="background:${pick(d.writeLatencyMs,1)}">
                            <div class="text-uppercase text-body-secondary" style="font-size:.6rem">Write</div>
                            <div class="fw-semibold" style="color:${pick(d.writeLatencyMs,0)}">${fmtMs(d.writeLatencyMs)} ms</div>
                        </div></div>
                    </div>
                    <div class="d-flex justify-content-between small text-body-secondary">
                        <span>IOPS ${fmtOps(d.readOpsPerSec + d.writeOpsPerSec)}</span>
                        <span>Q ${d.queueDepth.toFixed(1)}</span>
                        <span>Util ${d.utilizationPct.toFixed(1)}%</span>
                    </div>
                    <div class="progress mt-1" style="height:3px"><div class="progress-bar ${ub}" style="width:${Math.min(d.utilizationPct, 100)}%"></div></div>
                </div>
            </div></div>`;
        }

        async function fetchData() {
            try {
                const res = await fetch('/api/live');
                const data = await res.json();
                for (const id in data.text) { if (id === 'cpuUsage') continue; const el = document.getElementById(id); if (el) el.textContent = data.text[id]; }
                for (const id in data.html) { if (id === 'netBody') continue; const el = document.getElementById(id); if (el) el.innerHTML = data.html[id]; }

                const cpuPct = parseFloat(data.text.cpuUsage);
                if (!isNaN(cpuPct)) {
                    cpuChart.data.datasets[0].data = [cpuPct, 100 - cpuPct];
                    cpuChart.data.datasets[0].backgroundColor[0] = cpuColor(cpuPct);
                    cpuChart.update();
                    document.getElementById('cpuPct').textContent = cpuPct.toFixed(1) + '%';
                }

                if (data.networkRates && data.networkRates.length) {
                    const rx = data.networkRates.reduce((s, r) => s + r.rxBytesPerSec, 0);
                    const tx = data.networkRates.reduce((s, r) => s + r.txBytesPerSec, 0);
                    pushNet(rx, tx);
                    document.getElementById('netCharts').innerHTML = data.networkRates.map(r =>
                        '<span class="small font-monospace">' + r.name +
                        ' <i class="bi bi-arrow-down text-info"></i>' + fmtRate(r.rxBytesPerSec) +
                        ' <i class="bi bi-arrow-up text-warning"></i>' + fmtRate(r.txBytesPerSec) + '</span>'
                    ).join(' &nbsp; ');
                }

                // VDEV I/O chart, detail table + per-pool heatmaps
                if (data.poolLatencies && data.poolLatencies.length) {
                    const allDevs = data.poolLatencies.flatMap(p => p.devices);
                    const rd = allDevs.reduce((s, d) => s + d.readBytesPerSec, 0);
                    const wr = allDevs.reduce((s, d) => s + d.writeBytesPerSec, 0);
                    pushDisk(rd, wr);

                    document.getElementById('diskDetail').innerHTML = allDevs.map(r =>
                        '<tr class="border-bottom border-secondary">' +
                        '<td class="fw-semibold font-monospace">' + esc(r.deviceName) + '</td>' +
                        '<td class="text-end font-monospace">' + fmtRate(r.readBytesPerSec) + '</td>' +
                        '<td class="text-end font-monospace">' + fmtRate(r.writeBytesPerSec) + '</td></tr>'
                    ).join('');

                    for (const pool of data.poolLatencies) {
                        const grid = document.getElementById('heatmap-' + pool.poolName);
                        if (grid) {
                            grid.innerHTML = pool.devices.length
                                ? pool.devices.map(heatCell).join('')
                                : '<div class="col-12 text-body-secondary small"><i class="bi bi-info-circle me-1"></i>No I/O data</div>';
                        }
                    }
                }
            } catch (err) {
                console.error('live update failed:', err.message);
            } finally { setTimeout(fetchData, 1000); }
        }
        fetchData();
    })();
</script>
}
